<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GradBridge — Who Are You?</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet" />
 
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --navy: #08172E;
      --navy2: #0F2341;
      --teal: #0D6E6E;
      --teal-light: #1A9090;
      --gold: #E8A838;
      --amber: #F5C87A;
      --sand: #F2E8D5;
      --terra: #C45C35;
      --rose: #D4496A;
    }
 
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--navy);
      color: var(--sand);
      min-height: 100vh;
      overflow-x: hidden;
    }
    h1, h2, h3, h4, .syne { font-family: 'Syne', sans-serif; }
 
    /* ===== GRAIN ===== */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.03; pointer-events: none; z-index: 9999;
    }
 
    /* ===== NAV ===== */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 40px;
      background: rgba(8,23,46,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .logo-icon {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, var(--teal), var(--terra));
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif; font-weight: 800; color: #fff; font-size: 15px;
    }
    .logo-text { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 20px; color: var(--sand); }
    .nav-right { display: flex; align-items: center; gap: 12px; }
    .btn-ghost {
      padding: 8px 18px; border-radius: 8px; font-size: 13px; color: rgba(242,232,213,0.6);
      background: transparent; border: 1px solid rgba(255,255,255,0.1);
      cursor: pointer; transition: all 0.2s; text-decoration: none; font-family: 'Syne', sans-serif; font-weight: 600;
    }
    .btn-ghost:hover { background: rgba(255,255,255,0.07); color: var(--sand); }
    .btn-pill {
      padding: 9px 22px; border-radius: 100px; font-size: 13px; color: #fff;
      background: linear-gradient(135deg, var(--gold), var(--terra));
      border: none; cursor: pointer; font-family: 'Syne', sans-serif; font-weight: 700;
      transition: opacity 0.2s, transform 0.2s; text-decoration: none;
    }
    .btn-pill:hover { opacity: 0.88; transform: scale(1.02); }
 
    /* ===== HERO ===== */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 120px 24px 80px;
      position: relative;
      background:
        radial-gradient(ellipse at 15% 40%, rgba(13,110,110,0.22) 0%, transparent 55%),
        radial-gradient(ellipse at 85% 20%, rgba(232,168,56,0.12) 0%, transparent 50%),
        radial-gradient(ellipse at 70% 85%, rgba(196,92,53,0.12) 0%, transparent 50%),
        var(--navy);
    }
 
    /* Floating orbs */
    .orb {
      position: absolute; border-radius: 50%; pointer-events: none;
      filter: blur(60px); opacity: 0.12;
    }
    .orb-1 { width: 400px; height: 400px; background: var(--teal); top: 5%; left: -8%; animation: drift1 14s ease-in-out infinite; }
    .orb-2 { width: 300px; height: 300px; background: var(--gold); top: 60%; right: -5%; animation: drift2 18s ease-in-out infinite; }
    .orb-3 { width: 200px; height: 200px; background: var(--terra); bottom: 10%; left: 30%; animation: drift1 10s ease-in-out infinite reverse; }
 
    @keyframes drift1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(20px,-30px)} }
    @keyframes drift2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-25px,20px)} }
 
    /* dot grid pattern */
    .dot-grid {
      position: absolute; inset: 0; pointer-events: none; opacity: 0.07;
      background-image: radial-gradient(circle, rgba(242,232,213,0.7) 1px, transparent 1px);
      background-size: 32px 32px;
    }
 
    /* ===== HERO CONTENT ===== */
    .hero-content { position: relative; z-index: 2; text-align: center; max-width: 720px; }
 
    .eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 5px 14px; border-radius: 100px; font-size: 11px; letter-spacing: 0.1em;
      font-family: 'Syne', sans-serif; font-weight: 700; text-transform: uppercase;
      background: rgba(232,168,56,0.1); border: 1px solid rgba(232,168,56,0.3);
      color: var(--gold); margin-bottom: 28px;
    }
    .eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.7)} }
 
    .hero h1 {
      font-size: clamp(44px, 7vw, 80px);
      font-weight: 800; line-height: 1.0;
      color: var(--sand); margin-bottom: 22px; letter-spacing: -2px;
    }
    .hero h1 .accent { color: var(--gold); }
    .hero p {
      font-size: 18px; color: rgba(242,232,213,0.55);
      line-height: 1.7; max-width: 520px; margin: 0 auto 50px;
    }
 
    /* ===== ROLE SELECTION ===== */
    .roles-label {
      font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: rgba(242,232,213,0.35); margin-bottom: 20px;
    }
    .roles-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
      width: 100%; max-width: 860px; margin: 0 auto;
      position: relative; z-index: 2;
    }
 
    .role-card {
      position: relative; overflow: hidden;
      border-radius: 20px; padding: 32px 24px 28px;
      cursor: pointer; text-decoration: none;
      border: 1px solid rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.03);
      transition: transform 0.35s cubic-bezier(.22,.68,0,1.2), box-shadow 0.35s ease, border-color 0.3s ease;
      text-align: left;
      display: flex; flex-direction: column;
    }
    .role-card::before {
      content: ''; position: absolute; inset: 0; border-radius: 20px;
      opacity: 0; transition: opacity 0.4s;
    }
    .role-card:hover { transform: translateY(-8px) scale(1.01); }
 
    /* Business */
    .role-business { border-color: rgba(13,110,110,0.25); }
    .role-business::before { background: radial-gradient(ellipse at 30% 0%, rgba(13,110,110,0.25), transparent 70%); }
    .role-business:hover { border-color: rgba(13,110,110,0.6); box-shadow: 0 28px 60px rgba(13,110,110,0.2); }
    .role-business:hover::before { opacity: 1; }
 
    /* Student */
    .role-student { border-color: rgba(232,168,56,0.25); }
    .role-student::before { background: radial-gradient(ellipse at 30% 0%, rgba(232,168,56,0.2), transparent 70%); }
    .role-student:hover { border-color: rgba(232,168,56,0.6); box-shadow: 0 28px 60px rgba(232,168,56,0.15); }
    .role-student:hover::before { opacity: 1; }
 
    /* Job seeker */
    .role-jobseeker { border-color: rgba(196,92,53,0.25); }
    .role-jobseeker::before { background: radial-gradient(ellipse at 30% 0%, rgba(196,92,53,0.22), transparent 70%); }
    .role-jobseeker:hover { border-color: rgba(196,92,53,0.6); box-shadow: 0 28px 60px rgba(196,92,53,0.18); }
    .role-jobseeker:hover::before { opacity: 1; }
 
    .role-icon {
      width: 52px; height: 52px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 24px; margin-bottom: 20px; flex-shrink: 0;
    }
    .icon-business { background: rgba(13,110,110,0.2); border: 1px solid rgba(13,110,110,0.4); }
    .icon-student  { background: rgba(232,168,56,0.15); border: 1px solid rgba(232,168,56,0.4); }
    .icon-job      { background: rgba(196,92,53,0.18); border: 1px solid rgba(196,92,53,0.4); }
 
    .role-title {
      font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px;
      color: var(--sand); margin-bottom: 8px; line-height: 1.1;
    }
    .role-sub {
      font-size: 13px; color: rgba(242,232,213,0.45); line-height: 1.6;
      margin-bottom: 24px; flex: 1;
    }
    .role-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 24px; }
    .tag {
      font-size: 11px; padding: 3px 10px; border-radius: 100px;
      font-family: 'Syne', sans-serif; font-weight: 600;
    }
    .tag-teal  { background: rgba(13,110,110,0.2); border: 1px solid rgba(13,110,110,0.35); color: #5ecece; }
    .tag-gold  { background: rgba(232,168,56,0.15); border: 1px solid rgba(232,168,56,0.35); color: var(--amber); }
    .tag-terra { background: rgba(196,92,53,0.18); border: 1px solid rgba(196,92,53,0.35); color: #e08a68; }
 
    .role-cta {
      display: flex; align-items: center; gap: 8px;
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px;
      padding: 11px 20px; border-radius: 10px; width: 100%;
      justify-content: center; transition: filter 0.2s, transform 0.2s;
      position: relative; z-index: 1; border: none; cursor: pointer; text-decoration: none;
      color: #fff;
    }
    .role-cta:hover { filter: brightness(1.1); transform: scale(1.02); }
    .cta-business { background: linear-gradient(135deg, var(--teal), #0a5555); }
    .cta-student  { background: linear-gradient(135deg, var(--gold), #c98420); }
    .cta-job      { background: linear-gradient(135deg, var(--terra), #9c3e20); }
 
    .role-card .arrow {
      display: inline-block; transition: transform 0.3s ease;
    }
    .role-card:hover .arrow { transform: translateX(4px); }
 
    /* ===== MODAL ===== */
    .modal-backdrop {
      position: fixed; inset: 0; z-index: 200;
      background: rgba(8,23,46,0.85); backdrop-filter: blur(12px);
      display: flex; align-items: center; justify-content: center; padding: 24px;
      opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
    }
    .modal-backdrop.active { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--navy2); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px; padding: 40px; width: 100%; max-width: 480px;
      transform: scale(0.94) translateY(20px);
      transition: transform 0.35s cubic-bezier(.22,.68,0,1.2);
      position: relative;
    }
    .modal-backdrop.active .modal { transform: scale(1) translateY(0); }
 
    .modal-close {
      position: absolute; top: 18px; right: 20px;
      background: rgba(255,255,255,0.06); border: none; cursor: pointer;
      width: 32px; height: 32px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(242,232,213,0.5); transition: background 0.2s;
      font-size: 18px;
    }
    .modal-close:hover { background: rgba(255,255,255,0.12); color: var(--sand); }
 
    .modal-icon {
      width: 60px; height: 60px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; margin-bottom: 20px;
    }
    .modal h2 {
      font-family: 'Syne', sans-serif; font-weight: 800;
      font-size: 28px; color: var(--sand); margin-bottom: 6px;
    }
    .modal .modal-desc {
      font-size: 14px; color: rgba(242,232,213,0.5); margin-bottom: 28px; line-height: 1.6;
    }
 
    .form-group { margin-bottom: 16px; }
    .form-label {
      display: block; font-size: 12px; font-family: 'Syne', sans-serif; font-weight: 600;
      color: rgba(242,232,213,0.5); text-transform: uppercase; letter-spacing: 0.08em;
      margin-bottom: 8px;
    }
    .form-input, .form-select {
      width: 100%; padding: 12px 16px; border-radius: 10px; font-size: 14px;
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
      color: var(--sand); outline: none; font-family: 'DM Sans', sans-serif;
      transition: border-color 0.2s;
    }
    .form-input::placeholder { color: rgba(242,232,213,0.25); }
    .form-input:focus, .form-select:focus { border-color: rgba(232,168,56,0.5); }
    .form-select { appearance: none; cursor: pointer; }
    .form-select option { background: var(--navy2); }
 
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
 
    .divider {
      display: flex; align-items: center; gap: 12px;
      font-size: 12px; color: rgba(242,232,213,0.25); margin: 20px 0;
    }
    .divider::before, .divider::after {
      content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.08);
    }
 
    .btn-full {
      width: 100%; padding: 14px; border-radius: 12px; border: none; cursor: pointer;
      font-family: 'Syne', sans-serif; font-weight: 700; font-size: 15px; color: #fff;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn-full:hover { opacity: 0.9; transform: scale(1.01); }
 
    .modal-footer {
      text-align: center; margin-top: 16px; font-size: 13px; color: rgba(242,232,213,0.35);
    }
    .modal-footer a { color: var(--gold); text-decoration: none; }
    .modal-footer a:hover { text-decoration: underline; }
 
    /* type-pills for job seeker */
    .type-pills { display: flex; gap: 10px; margin-top: 8px; }
    .type-pill {
      flex: 1; padding: 10px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.04); text-align: center; cursor: pointer;
      transition: all 0.2s;
    }
    .type-pill .pill-icon { font-size: 20px; margin-bottom: 4px; }
    .type-pill .pill-label { font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700; color: rgba(242,232,213,0.5); }
    .type-pill.selected { border-color: rgba(196,92,53,0.5); background: rgba(196,92,53,0.12); }
    .type-pill.selected .pill-label { color: #e08a68; }
 
    /* ===== TRUST STRIP ===== */
    .trust-strip {
      position: relative; z-index: 2;
      display: flex; align-items: center; justify-content: center;
      gap: 32px; margin-top: 52px; flex-wrap: wrap;
    }
    .trust-item {
      display: flex; align-items: center; gap: 8px;
      font-size: 12px; color: rgba(242,232,213,0.35); font-family: 'Syne', sans-serif; font-weight: 600;
    }
    .trust-dot { width: 5px; height: 5px; border-radius: 50%; background: rgba(232,168,56,0.5); }
 
    /* ===== STATS ===== */
    .stats-row {
      display: flex; gap: 0; width: 100%; max-width: 860px;
      margin: 0 auto; margin-top: 60px; position: relative; z-index: 2;
      border-radius: 16px; overflow: hidden;
      border: 1px solid rgba(255,255,255,0.07);
      background: rgba(255,255,255,0.025);
    }
    .stat { flex: 1; padding: 22px 20px; text-align: center; border-right: 1px solid rgba(255,255,255,0.07); }
    .stat:last-child { border-right: none; }
    .stat-num { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 26px; color: var(--gold); }
    .stat-lbl { font-size: 11px; color: rgba(242,232,213,0.4); margin-top: 3px; font-family: 'Syne', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
 
    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      nav { padding: 14px 20px; }
      .nav-right .btn-ghost { display: none; }
      .roles-grid { grid-template-columns: 1fr; max-width: 420px; }
      .stats-row { flex-direction: column; }
      .stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.07); }
      .stat:last-child { border-bottom: none; }
      .form-row { grid-template-columns: 1fr; }
    }
 
    /* ===== ANIMATIONS ===== */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { opacity: 0; animation: fadeUp 0.6s ease forwards; }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.25s; }
    .delay-3 { animation-delay: 0.4s; }
    .delay-4 { animation-delay: 0.55s; }
    .delay-5 { animation-delay: 0.7s; }
  </style>
</head>
<body>
 
  <!-- NAV -->
  <nav>
    <a href="#" class="logo">
      <div class="logo-icon">G</div>
      <span class="logo-text">GradBridge</span>
    </a>
    <div class="nav-right">
      <a href="#" class="btn-ghost">Sign In</a>
      <a href="#" class="btn-pill">Get Started</a>
    </div>
  </nav>
 
  <!-- HERO -->
  <section class="hero">
    <div class="dot-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
 
    <div class="hero-content">
      <div class="eyebrow fade-up delay-1">
        <div class="dot"></div>
        Botswana's Career & Business Hub
      </div>
 
      <h1 class="fade-up delay-2">
        Who Are <span class="accent">You</span><br/>on GradBridge?
      </h1>
      <p class="fade-up delay-3">
        Tell us who you are and we'll personalise your entire experience — from finding talent to landing your dream role.
      </p>
    </div>
 
    <!-- ROLE CARDS -->
    <div class="roles-grid fade-up delay-4">
 
      <!-- BUSINESS -->
      <a href="#" class="role-card role-business" onclick="openModal('business'); return false;">
        <div class="role-icon icon-business">🏢</div>
        <div class="role-title">I'm a Business</div>
        <p class="role-sub">Post jobs, run training programmes, advertise scholarships, and find the best local talent Botswana has to offer.</p>
        <div class="role-tags">
          <span class="tag tag-teal">Post Jobs</span>
          <span class="tag tag-teal">Training</span>
          <span class="tag tag-teal">Scholarships</span>
        </div>
        <span class="role-cta cta-business">
          Register Business <span class="arrow">→</span>
        </span>
      </a>
 
      <!-- STUDENT -->
      <a href="#" class="role-card role-student" onclick="openModal('student'); return false;">
        <div class="role-icon icon-student">🎓</div>
        <div class="role-title">I'm a Student</div>
        <p class="role-sub">Find internships, attachment programmes, scholarships, and company-run courses to complement your degree.</p>
        <div class="role-tags">
          <span class="tag tag-gold">Internships</span>
          <span class="tag tag-gold">Attachment</span>
          <span class="tag tag-gold">Scholarships</span>
        </div>
        <span class="role-cta cta-student">
          Create Student Profile <span class="arrow">→</span>
        </span>
      </a>
 
      <!-- JOB SEEKER -->
      <a href="#" class="role-card role-jobseeker" onclick="openModal('jobseeker'); return false;">
        <div class="role-icon icon-job">💼</div>
        <div class="role-title">I'm Looking for Work</div>
        <p class="role-sub">Browse permanent roles or internship opportunities, apply directly, and get matched with employers looking for your skills.</p>
        <div class="role-tags">
          <span class="tag tag-terra">Permanent Jobs</span>
          <span class="tag tag-terra">Internships</span>
        </div>
        <span class="role-cta cta-job">
          Find Opportunities <span class="arrow">→</span>
        </span>
      </a>
 
    </div>
 
    <!-- STATS -->
    <div class="stats-row fade-up delay-5">
      <div class="stat">
        <div class="stat-num">500+</div>
        <div class="stat-lbl">Companies</div>
      </div>
      <div class="stat">
        <div class="stat-num">12,000+</div>
        <div class="stat-lbl">Registered Users</div>
      </div>
      <div class="stat">
        <div class="stat-num">3,400+</div>
        <div class="stat-lbl">Active Listings</div>
      </div>
      <div class="stat">
        <div class="stat-num">800+</div>
        <div class="stat-lbl">Scholarships Posted</div>
      </div>
    </div>
 
    <!-- TRUST -->
    <div class="trust-strip">
      <span class="trust-item"><div class="trust-dot"></div> 100% Free to Join</span>
      <span class="trust-item"><div class="trust-dot"></div> Botswana-Focused</span>
      <span class="trust-item"><div class="trust-dot"></div> Verified Companies</span>
      <span class="trust-item"><div class="trust-dot"></div> Direct Applications</span>
    </div>
  </section>
 
 
  <!-- ============ MODAL: BUSINESS ============ -->
  <div class="modal-backdrop" id="modal-business">
    <div class="modal">
      <button class="modal-close" onclick="closeModal('business')">✕</button>
      <div class="modal-icon icon-business" style="background:rgba(13,110,110,0.2); border:1px solid rgba(13,110,110,0.4);">🏢</div>
      <h2>Register Your Business</h2>
      <p class="modal-desc">Set up your company profile to start posting jobs, training programmes, and scholarships.</p>
 
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Company Name</label>
          <input class="form-input" type="text" placeholder="e.g. Debswana" />
        </div>
        <div class="form-group">
          <label class="form-label">Industry</label>
          <select class="form-select">
            <option value="">Select industry</option>
            <option>Banking & Finance</option>
            <option>Mining & Resources</option>
            <option>Technology</option>
            <option>Healthcare</option>
            <option>Retail & Trade</option>
            <option>Construction</option>
            <option>Education</option>
            <option>Government</option>
            <option>Other</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Work Email</label>
        <input class="form-input" type="email" placeholder="admin@company.co.bw" />
      </div>
